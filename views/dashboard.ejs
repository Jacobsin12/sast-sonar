<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/header') %>
</head>
<body style="background-color: #050509; color: white;">
    <div id="tsparticles"></div>

    <nav class="navbar navbar-expand-lg glass-panel mt-3 mx-3 p-3">
        <div class="container-fluid">
            <span class="navbar-brand fw-bold text-neon-cyan">
                <i class='bx bx-pulse'></i> SONAR_CORE_v1.0
            </span>
            <div class="d-flex align-items-center">
                <span class="text-muted me-3 small">[ USR: <%= user %> ]</span>
                <a href="/login" class="btn btn-outline-tech btn-sm">
                    <i class='bx bx-log-out'></i>
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid p-4">
        <div class="d-flex align-items-center mb-4">
            <h1 class="fw-bold mb-0 text-neon-cyan">Estado del Sistema</h1>
            <span class="badge bg-success badge-tech ms-3">ONLINE</span>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card glass-panel h-100 p-4">
                    <h3 class="text-neon-cyan">
                        <i class='bx bx-server'></i> Infraestructura
                    </h3>
                    <p class="text-muted small">Motores de observabilidad de hardware.</p>
                    <div class="d-grid gap-3 mt-4">
                        <a href="/metrics" target="_blank" class="btn btn-outline-tech btn-lg">
                            <i class='bx bx-code-block'></i> Métricas RAW
                        </a>
                        <a href="http://34.51.110.74:3001" target="_blank" class="btn btn-tech-pink">
                            <i class='bx bx-line-chart'></i> Grafana Global
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card glass-panel h-100 p-4">
                    <h3 class="text-neon-cyan">
                        <i class='bx bx-wrench'></i> Inventario Ferretería
                    </h3>
                    <p class="text-muted small">Estado actual de la base de datos.</p>
                    
                    <div class="table-responsive mt-3" style="background: transparent !important;">
                        <table class="table table-sm small" style="background-color: transparent !important; color: white !important; border-color: transparent !important;">
                            <thead>
                                <tr>
                                    <th style="background: transparent !important; color: #ff0055 !important; border-bottom: 2px solid #ff0055 !important; font-family: 'Oswald', sans-serif;">ID</th>
                                    <th style="background: transparent !important; color: #ff0055 !important; border-bottom: 2px solid #ff0055 !important; font-family: 'Oswald', sans-serif;">PRODUCTO</th>
                                    <th style="background: transparent !important; color: #ff0055 !important; border-bottom: 2px solid #ff0055 !important; font-family: 'Oswald', sans-serif;">STOCK</th>
                                    <th style="background: transparent !important; color: #ff0055 !important; border-bottom: 2px solid #ff0055 !important; font-family: 'Oswald', sans-serif;">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody style="background: transparent !important;">
                                <% productos.forEach(p => { %>
                                    <tr style="background-color: rgba(255, 255, 255, 0.05) !important;">
                                        <td style="background: transparent !important; color: white !important; border: none !important; padding: 12px !important;">#<%= p.id %></td>
                                        <td style="background: transparent !important; color: white !important; border: none !important; padding: 12px !important; font-weight: bold;"><%= p.nombre %></td>
                                        <td style="background: transparent !important; color: #00f2fe !important; border: none !important; padding: 12px !important; font-weight: bold; text-shadow: 0 0 5px rgba(0, 242, 254, 0.5);"><%= p.stock %></td>
                                        <td style="background: transparent !important; border: none !important; padding: 12px !important;">
                                            <span class="badge badge-tech <%= p.estado === 'OK' ? 'bg-success' : 'bg-warning text-dark' %>">
                                                <%= p.estado %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/scripts') %>
</body>
</html>